; fib.vas -- iterative Fibonacci: F(0)=0, F(1)=1, F(n)=F(n-1)+F(n-2)
; Computes F(20) and returns it as exit code
; Tests: MOVI, ADD, CMP, JGE, JMP, multiple virtual registers, loops

	global _start

	xor	eax, eax
	mov	rbx, 1
	mov	rcx, 20
	mov	rdx, 1

loop:
	cmp	rdx, rcx
	jge	done
	add	rbx, rax
	mov	rax, rbx
	mov	rsi, 1
	add	rdx, rsi
	jmp	loop

done:
    ; v1 holds F(20) = 6765
	mov	rax, rbx
	ret
