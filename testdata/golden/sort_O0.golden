; sort.vas -- bubble sort an array of 8 qwords
; Tests: LOAD/STORE with computed address, nested loops, CMP/conditional jumps

	default rel

	section .data
data:
	dq 5, 3, 8, 1, 9, 2, 7, 4

	section .text
	global _start

_start:
	mov	rax, 8
	push	rax
	mov	rbx, 0

outer:
	pop	rax
	mov	rsi, rax
	push	rax
	mov	rax, 1
	sub	rsi, rax
	sub	rsi, rbx
	mov	rcx, 0
	mov	rdx, 0

inner:
	cmp	rdx, rsi
	jge	check_swap

    ; addr of a[j] = data + j*8
	mov	rdi, rdx
	imul	rdi, 8
	lea	rax, [data]
	add	rdi, rax
	mov	r9, [rdi]

    ; addr of a[j+1] = data + (j+1)*8
	mov	rdi, rdx
	mov	r8, 1
	add	rdi, r8
	imul	rdi, 8
	lea	rax, [data]
	add	rdi, rax
	mov	r8, [rdi]

    ; if a[j] > a[j+1], swap
	cmp	r9, r8
	jle	no_swap

; swap: STORE a[j+1] (v6) to a[j], a[j] (v7) to a[j+1]
swap:
	mov	rdi, rdx
	imul	rdi, 8
	lea	rax, [data]
	add	rdi, rax
	mov	[rdi], r8

	mov	rdi, rdx
	mov	rax, 1
	add	rdi, rax
	imul	rdi, 8
	lea	rax, [data]
	add	rdi, rax
	mov	[rdi], r9

	mov	rcx, 1

no_swap:
	mov	rax, 1
	add	rdx, rax
	jmp	inner

check_swap:
	cmp	rcx, 0
	je	done
	mov	rax, 1
	add	rbx, rax
	jmp	outer

done:
	pop	rax
	lea	rax, [data]
	mov	rax, [rax]
    
    ; exit with result
	mov	rdi, rax
	mov	rax, 60
	syscall
